        "@vanillagreen/pi-qol": {
          "enabled": true,
          "compactPrompt": false,
          "thinkingTimer.enabled": true
        }
      }
    }
  },
  "enabledModels": [
    "anthropic/claude-sonnet-4-6",
    "openai-codex/gpt-5.3-codex",
    "anthropic/claude-opus-4-8",
    "openai-codex/gpt-5.5"
